# Server
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/engineering

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=engineering

# Claude worker (API mode). CLI mode (`claude -p`) uses the CLI's own login instead.
ANTHROPIC_API_KEY=sk-ant-...
# WORKER_MODE=api   # or "cli"
# Model for agent runs (default claude-opus-4-8). Use claude-haiku-4-5 to run ~5x cheaper.
# ANTHROPIC_MODEL=claude-opus-4-8

# Delivery backend (ENG-017): "local" commits the agent's code to a local git repo under ./workspace
# (no GitHub needed — QA verifies real code, tickets can reach `done` offline). Leave unset to use the
# GitHub adapter when the GITHUB_* vars below are set, or to no-op delivery when they aren't.
DELIVERY_BACKEND=

# GitHub delivery (optional). When set, the worker opens/merges PRs for tickets.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main
# Deploy (optional). Actions workflow dispatched on the human-gated ship step.
# Leave empty unless deploying via GitHub Actions. NOTE: no inline comments after the value —
# docker compose's env_file parser keeps everything after `=` (a trailing comment becomes the value).
# Example value: deploy.yml
GITHUB_DEPLOY_WORKFLOW=
GITHUB_DEPLOY_REF=main

# Persistence backend for agent state (tracker + knowledge base): postgres (default) or github.
PERSISTENCE_BACKEND=postgres
GITHUB_DOCS_PREFIX=docs

# Kappa-style consensus (ENG-016 / PRD-001). Off by default; trigger a round per epic via
# POST /api/epics/:id/consensus. Phase 1 is advisory (records the round + agreement score, no gate).
CONSENSUS_ENABLED=false
# CONSENSUS_INPUT_MODE=rank        # "rank" (Borda + Kendall/Krippendorff) or "pick" (Fleiss)
# CONSENSUS_THRESHOLD=0.6          # agreement gate (Landis–Koch "substantial")
# CONSENSUS_ADVISORY=true          # false → promote to a real architecture_decision gate (Phase 2)
# CONSENSUS_TIEBREAKER=human       # "human" (escalate to the gate) or "casting_vote"
